  <!-- JS: Training + Contact modals -->
  <script>
    // Training removed from navigation and UI

    // Contact modal
    const contactLink = document.querySelector('a[href="#contact"]');
    const contactModal = document.getElementById('contact-modal');
    const contactClose = document.getElementById('contact-modal-close');

    if (contactLink && contactModal && contactClose) {
      contactLink.addEventListener('click', function (e) {
        e.preventDefault();
        contactModal.classList.remove('hidden');
        contactModal.classList.add('flex');
      });

      contactClose.addEventListener('click', function () {
        contactModal.classList.add('hidden');
        contactModal.classList.remove('flex');
      });

      contactModal.addEventListener('click', function (e) {
        if (e.target === contactModal) {
          contactModal.classList.add('hidden');
          contactModal.classList.remove('flex');
        }
      });
    }

    // Product preview + 15-day trial modal with license code
    const productModal = document.getElementById('product-modal');
    const productClose = document.getElementById('product-modal-close');
    const productGif = document.getElementById('product-modal-gif');
    const productTitle = document.getElementById('product-modal-title');
    const productDesc = document.getElementById('product-modal-desc');
    const productPrice = document.getElementById('product-modal-price');
    const downloadBtn = document.getElementById('product-download-btn');
    const purchaseCodeBtn = document.getElementById('purchase-code-btn');
    const trialStatus = document.getElementById('trial-status');
    const trialDaysLeft = document.getElementById('trial-days-left');
    const licenseInputSection = document.getElementById('license-input-section');
    const licenseCodeInput = document.getElementById('license-code-input');
    const activateLicenseBtn = document.getElementById('activate-license-btn');

    let currentProductId = null;

    function getTrialData(productId) {
      const trialKey = 'trial_' + productId;
      const data = JSON.parse(localStorage.getItem(trialKey) || '{}');
      if (!data.startDate) {
        data.startDate = new Date().toISOString();
        localStorage.setItem(trialKey, JSON.stringify(data));
      }
      return data;
    }

    function isTrialExpired(productId) {
      const data = getTrialData(productId);
      const startDate = new Date(data.startDate);
      const now = new Date();
      const daysElapsed = Math.floor((now - startDate) / (1000 * 60 * 60 * 24));
      return daysElapsed >= 15;
    }

    function getTrialDaysRemaining(productId) {
      const data = getTrialData(productId);
      const startDate = new Date(data.startDate);
      const now = new Date();
      const daysElapsed = Math.floor((now - startDate) / (1000 * 60 * 60 * 24));
      return Math.max(0, 15 - daysElapsed);
    }

    function isLicensed(productId) {
      const licensed = JSON.parse(localStorage.getItem('licensed_products') || '{}');
      return licensed[productId] || false;
    }

    function openProductModal(opts) {
      currentProductId = opts.id;
      productGif.src = opts.gif || '';
      productTitle.textContent = opts.title || 'Product';
      productDesc.textContent = opts.desc || '';
      productPrice.textContent = opts.price || '0.00';
      downloadBtn.href = opts.file || '#';
      updateTrialUI(opts.id);
      productModal.classList.remove('hidden');
      productModal.classList.add('flex');
    }

    function updateTrialUI(productId) {
      const licensed = isLicensed(productId);
      const expired = isTrialExpired(productId);
      const daysLeft = getTrialDaysRemaining(productId);

      if (licensed) {
        trialStatus.className = 'mt-4 p-3 rounded-lg bg-green-50 border border-green-200';
        trialDaysLeft.textContent = '✓ License activated. Full access granted.';
        trialDaysLeft.className = 'text-sm text-green-800 mt-1';
        downloadBtn.textContent = 'Download (Licensed)';
        downloadBtn.classList.remove('pointer-events-none');
        purchaseCodeBtn.classList.add('hidden');
        licenseInputSection.classList.add('hidden');
      } else if (expired) {
        trialStatus.className = 'mt-4 p-3 rounded-lg bg-red-50 border border-red-200';
        trialDaysLeft.textContent = '⚠ Trial expired. Purchase a license code to continue.';
        trialDaysLeft.className = 'text-sm text-red-800 mt-1';
        downloadBtn.textContent = 'Download (Locked - Enter Code)';
        downloadBtn.classList.add('pointer-events-none');
        purchaseCodeBtn.classList.remove('hidden');
        licenseInputSection.classList.remove('hidden');
      } else {
        trialStatus.className = 'mt-4 p-3 rounded-lg bg-blue-50 border border-blue-200';
        trialDaysLeft.textContent = daysLeft + ' days left in your free trial';
        trialDaysLeft.className = 'text-sm text-blue-800 mt-1';
        downloadBtn.textContent = 'Download (Free Trial - ' + daysLeft + ' days)';
        downloadBtn.classList.remove('pointer-events-none');
        purchaseCodeBtn.classList.add('hidden');
        licenseInputSection.classList.add('hidden');
      }
    }

    function closeProductModal() {
      productModal.classList.add('hidden');
      productModal.classList.remove('flex');
      currentProductId = null;
    }

    document.querySelectorAll('a.js-view-download').forEach(a => {
      a.addEventListener('click', function (e) {
        e.preventDefault();
        const card = a.closest('.p-5') || a.closest('div');
        const titleEl = card ? card.querySelector('h3, h4, h2') : null;
        const descEl = card ? card.querySelector('p') : null;
        const title = titleEl ? titleEl.textContent.trim() : 'Detail demo';
        const desc = descEl ? descEl.textContent.trim() : '';
        const file = a.getAttribute('data-file') || '/downloads/demo.zip';
        const gif = a.getAttribute('data-gif') || '';
        const price = a.getAttribute('data-price') || '0.00';
        const id = (a.getAttribute('data-file') || title).replace(/[^a-z0-9\-]/gi, '_');
        openProductModal({ id, title, desc, file, gif, price });
      });
    });

    if (productClose) productClose.addEventListener('click', closeProductModal);
    if (productModal) productModal.addEventListener('click', function (e) { if (e.target === productModal) closeProductModal(); });

    // Purchase code button: open email client to Arqwell
    if (purchaseCodeBtn) purchaseCodeBtn.addEventListener('click', function () {
      window.location.href = 'mailto:hello@arqwell.com?subject=Purchase License Code for ' + (productTitle.textContent || 'Product');
    });

    // Activate license code
    if (activateLicenseBtn) activateLicenseBtn.addEventListener('click', function () {
      const code = licenseCodeInput.value.trim();
      if (!code) { alert('Please enter a license code.'); return; }
      // In production: verify the code server-side against a database
      const licensed = JSON.parse(localStorage.getItem('licensed_products') || '{}');
      licensed[currentProductId] = true;
      localStorage.setItem('licensed_products', JSON.stringify(licensed));
      updateTrialUI(currentProductId);
      licenseCodeInput.value = '';
      alert('License activated! You now have full access.');
    });

    // Block download if trial expired and no license
    if (downloadBtn) downloadBtn.addEventListener('click', function (e) {
      if (downloadBtn.classList.contains('pointer-events-none')) {
        e.preventDefault();
        alert('Trial expired. Please enter a valid license code or purchase one by emailing Arqwell.');
      }
    });
  </script>

  <!-- Single Footer -->
  <script>
    (function(){
      const openBtn = document.getElementById('openServicesBtn');
      const modal = document.getElementById('get-services-modal');
      const closeBtn = document.getElementById('get-services-close');
      const cancelBtn = document.getElementById('get-services-cancel');
      const form = document.getElementById('get-services-form');
      const fileInput = document.getElementById('services-file');
      const vectorCheckbox = document.getElementById('vector-checkbox');
      const vectorControls = document.getElementById('vector-controls');
      const vectorSheets = document.getElementById('vector-sheets');
      const vectorEstimateSpan = document.getElementById('vector-estimate');
      const vectorHidden = document.getElementById('vectorization_estimate_input');

      function open() { if (modal) { modal.classList.remove('hidden'); modal.classList.add('flex'); } }
      function close() { if (modal) { modal.classList.add('hidden'); modal.classList.remove('flex'); } }

      if (openBtn) openBtn.addEventListener('click', function(e){ e.preventDefault(); open(); });
      if (closeBtn) closeBtn.addEventListener('click', function(){ close(); });
      if (cancelBtn) cancelBtn.addEventListener('click', function(){ close(); });
      if (modal) modal.addEventListener('click', function(e){ if (e.target === modal) close(); });

      // Vectorization UI logic
      function updateEstimate() {
        const sheets = Math.max(0, parseInt(vectorSheets && vectorSheets.value) || 0);
        const estimate = sheets * 300;
        if (vectorEstimateSpan) vectorEstimateSpan.textContent = '$' + estimate.toLocaleString();
        if (vectorHidden) vectorHidden.value = estimate;
      }

      if (vectorCheckbox) {
        vectorCheckbox.addEventListener('change', function(){
          if (!vectorControls) return;
          if (vectorCheckbox.checked) {
            vectorControls.classList.remove('hidden');
          } else {
            vectorControls.classList.add('hidden');
          }
          updateEstimate();
        });
      }

      if (vectorSheets) {
        vectorSheets.addEventListener('input', updateEstimate);
      }

      if (form) {
        const messageField = form.querySelector('textarea[name="message"]');
        form.addEventListener('submit', function(e){
          const file = fileInput && fileInput.files && fileInput.files[0];
          if (file && file.size > 10 * 1024 * 1024) {
            e.preventDefault();
            alert('The file you selected is larger than 10MB. Please email large files to imani@isa-arqwell.com instead.');
            return;
          }

          // If vectorization selected, validate sheets and include estimate in submission
          if (vectorCheckbox && vectorCheckbox.checked) {
            const sheets = Math.max(0, parseInt(vectorSheets && vectorSheets.value) || 0);
            if (sheets < 1) {
              e.preventDefault();
              alert('Please enter the number of sheets for CAD Vectorization (minimum 1).');
              return;
            }
            const estimate = sheets * 300;
            if (vectorHidden) vectorHidden.value = estimate;
            // Append a brief summary to the message field so it appears in the email
            if (messageField) {
              const note = '\n\n[CAD Vectorization] Sheets: ' + sheets + ' — Estimated cost: $' + estimate.toLocaleString();
              messageField.value = (messageField.value || '') + note;
            }
          }

          // Let the form submit to the configured form endpoint (FormSubmit.co). Show a quick confirmation.
          setTimeout(function(){ close(); alert('Request submitted. We will contact you soon.'); }, 500);
        });
      }
    })();
  </script>

